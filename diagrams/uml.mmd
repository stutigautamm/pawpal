classDiagram
    class Owner {
        +String name
        +int available_time_minutes
        +List~Pet~ pets
        +add_pet(pet: Pet) void
        +update_availability(minutes: int) void
        +get_all_tasks() List~Task~
    }

    class Pet {
        +String name
        +String breed
        +int age
        +List~Task~ tasks
        +add_task(task: Task) void
        +remove_task(task_id: String) bool
        +get_total_task_duration() int
    }

    class Task {
        +String id
        +String name
        +int duration
        +Priority priority
        +bool is_completed
        +String pet_name
        +update_task(name: String, duration: int, priority: Priority) void
        +mark_complete() void
    }

    class Priority {
        <<enumeration>>
        LOW = 1
        MEDIUM = 2
        HIGH = 3
    }

    class Scheduler {
        +Owner owner
        +List~Task~ daily_plan
        +List~String~ reasoning_log
        +generate_schedule() List~Task~
        +get_reasoning() String
    }

    %% Relationships
    Owner "1" o-- "*" Pet : owns
    Pet "1" o-- "*" Task : has
    Task ..> Pet : refers to (by name)
    Task ..> Priority : uses
    Scheduler "1" --> "1" Owner : plans_for
    Scheduler ..> Pet : reads
    Scheduler ..> Task : orders
